package dev.cajeta.ifx.ios;

import cajeta.ifx.WindowBackend;
import cajeta.ifx.Window;
import cajeta.ifx.Surface;
import cajeta.ifx.WindowEvent;
import cajeta.ifx.BackendRegistry;

/**
 * UIKitWindowBackend — the iOS window/surface backend for ifx, FFI-binding UIKit (UIView + CAMetalLayer).
 * Registers itself so the ifx dispatcher can select it on iOS. v0.1 skeleton — no FFI yet.
 *
 * Audio (CoreAudio / AVAudioEngine) and input (UIKit touch + GameController) backends are sibling classes in this library; see
 * documents/cajeta-ifx-ios-plan.md.
 */
public final class UIKitWindowBackend implements WindowBackend {

    /** Called at load to register this backend with ifx. */
    public static void register() {
        BackendRegistry.registerWindow(new UIKitWindowBackend());
    }

    public boolean probe()    { return false; }       // TODO: detect the iOS environment
    public int32   priority() { return 100; }
    public String  name()     { return "ios"; }

    public Window createWindow(String title, uint32 width, uint32 height) {
        return null;   // TODO: create a window via UIKit (UIView + CAMetalLayer)
    }

    public Surface surfaceOf(Window w) {
        return null;   // TODO: opaque surface handle for VK_EXT_metal_surface (MoltenVK)
    }

    public WindowEvent[] poll(Window w) {
        return null;   // TODO: drain the iOS event queue
    }

    public void destroy(Window w) { }
}
